{
  "name": "ababil-shop",
  "version": "0.0.1",
  "private": true,
  "packageManager": "npm@10.2.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:storefront": "turbo dev --filter=@ababil/storefront",
    "dev:dashboard": "turbo dev --filter=@ababil/dashboard",
    "dev:legacy": "cd client && npm run dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore",
    "clean": "turbo clean && find . -name node_modules -type d -maxdepth 3 -exec rm -rf {} +",
    "supabase:start": "supabase start",
    "supabase:push": "supabase db push",
    "supabase:reset": "supabase db reset",
    "supabase:types": "supabase gen types typescript --local --schema public > packages/supabase/src/types.generated.ts"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
